// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id       String   @id @default(cuid())
  email    String   @unique
  password String
  nombre   String
  creadoEn DateTime @default(now())
}

model Publicacion {
  id               String            @id @default(cuid())
  titulo           String
  contenido        String?
  imagen           String?
  slug             String            @unique
  fuente           FuentePublicacion @default(MANUAL)
  instagramId      String?           @unique
  instagramUrl     String?
  publicado        Boolean           @default(true)
  creadoEn         DateTime          @default(now())
  actualizadoEn    DateTime          @updatedAt
}

model Contacto {
  id       String   @id @default(cuid())
  nombre   String
  email    String
  telefono String?
  mensaje  String
  leido    Boolean  @default(false)
  creadoEn DateTime @default(now())
}

enum FuentePublicacion {
  MANUAL
  INSTAGRAM
}
